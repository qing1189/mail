# ════════════════════════════════════════════════════════════════════
#  MS Mail Reg Tool — Docker Compose 环境变量
#
#  用法:
#    cp .env.example .env       # 复制后按需修改
#    docker compose up -d       # compose 会自动读取同目录 .env
#
#  注意:.env 文件已被 .gitignore 排除,不会进版本库
# ════════════════════════════════════════════════════════════════════

# ─── 端口映射 ───────────────────────────────────────────
# HOST_PORT  — 宿主机暴露的端口 (浏览器访问用)
# WEB_PORT   — 容器内 uvicorn 监听端口 (一般不用改)
HOST_PORT=8787
WEB_PORT=8787

# ─── 镜像与容器 ─────────────────────────────────────────
IMAGE_TAG=ms-mail-reg-tool:latest
CONTAINER_NAME_WEB=ms-mail-web
CONTAINER_NAME_CLI=ms-mail-cli

# ─── 运行时 ─────────────────────────────────────────────
# TZ            — 容器时区
# SHM_SIZE      — Firefox 渲染必须的共享内存,默认 64M 会崩,建议 ≥ 512M
# RESTART_POLICY — 容器重启策略 (no | always | on-failure | unless-stopped)
TZ=Asia/Shanghai
SHM_SIZE=1gb
RESTART_POLICY=unless-stopped

# ─── 数据目录 (容器内路径,一般不用改) ──────────────────
MAIL_DATA_DIR=/data

# ─── Firefox / 浏览器 ───────────────────────────────────
# MOZ_HEADLESS=1 强制 Firefox 无头模式 (容器无图形界面,必须开)
MOZ_HEADLESS=1

# ─── 首次启动时生成的默认 config.json ───────────────────
# 仅在 ./data/config.json 不存在或为空时使用;
# 之后用户在 Web 控制台修改的设置会持久化到 config.json
DEFAULT_HEADLESS=true
DEFAULT_BROWSER_PATH=/usr/bin/firefox-esr
DEFAULT_PROFILE_ROOT=Profiles
